# NanoClaw Railway Template Environment
# Copy this to .env and fill in your values

# Required: API Key
# This can be from Anthropic OR any compatible provider (OpenRouter, Together AI, etc.)
ANTHROPIC_API_KEY=your-api-key-here

# Optional: Custom API Base URL (for non-Anthropic providers)
# Anthropic: leave empty (default: https://api.anthropic.com)
# OpenRouter: https://openrouter.ai/api/v1
# Together AI: https://api.together.xyz/v1
# Fireworks: https://api.fireworks.ai/inference/v1
# Ollama (local): http://localhost:11434/v1
# ANTHROPIC_BASE_URL=

# Optional: Additional auth token (rarely needed)
# ANTHROPIC_AUTH_TOKEN=

# Optional: Claude Code OAuth Token
# CLAUDE_CODE_OAUTH_TOKEN=your-oauth-token

# Assistant Configuration
ASSISTANT_NAME=Andy
ASSISTANT_HAS_OWN_NUMBER=false

# Container Configuration
CONTAINER_IMAGE=nanoclaw-agent:latest
CONTAINER_TIMEOUT=1800000
MAX_CONCURRENT_CONTAINERS=5
IDLE_TIMEOUT=1800000

# Logging
LOG_LEVEL=info

# Timezone
TZ=UTC
